@model VillaUpdateDTO

@{
    ViewBag.Title = "Edit Villa";
    Layout = "_Layout";
}

<div class="container p-4 border">
    <h1 class="text-primary"><i class="fas fa-edit me-2"></i>Edit Villa</h1>
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" placeholder="Enter villa name (max 30 characters)" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Details" class="form-label"></label>
            <textarea asp-for="Details" class="form-control" rows="4" placeholder="Enter villa details"></textarea>
            <span asp-validation-for="Details" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Rate" class="form-label"></label>
            <input asp-for="Rate" type="number" step="0.01" class="form-control" placeholder="Enter nightly rate" />
            <span asp-validation-for="Rate" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Occupancy" class="form-label"></label>
            <input asp-for="Occupancy" type="number" class="form-control" placeholder="Enter max occupancy" />
            <span asp-validation-for="Occupancy" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Sqft" class="form-label"></label>
            <input asp-for="Sqft" type="number" class="form-control" placeholder="Enter square footage" />
            <span asp-validation-for="Sqft" class="text-danger"></span>
        </div>

        <!-- ✅ الصورة الحالية -->
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="form-group mb-3">
                <label class="form-label">Current Image</label>
                <div class="mb-2">
                    <img src="@Model.ImageUrl" alt="Villa Image" class="img-fluid" style="max-width: 200px;" />
                </div>
            </div>
        }

        <div class="form-group mb-3">
            <label class="form-label">Upload New Image (optional)</label>
            <input type="file" name="ImageFile" class="form-control" />
        </div>

        <input type="hidden" asp-for="ImageUrl" />

        <div class="form-group mb-3">
            <label asp-for="Amenity" class="form-label"></label>
            <input asp-for="Amenity" class="form-control" placeholder="Enter amenities (e.g., Pool, Wi-Fi)" />
            <span asp-validation-for="Amenity" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Update</button>
            <a asp-action="Index" class="btn btn-secondary ms-2"><i class="fas fa-arrow-left me-1"></i>Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
