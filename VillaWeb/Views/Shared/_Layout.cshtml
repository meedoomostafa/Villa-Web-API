<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - VillaWeb</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/VillaWeb.styles.css" asp-append-version="true"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Animated Background -->
    <div class="animated-bg"></div>
    
    <header>
        <nav class="navbar navbar-expand-lg navbar-glass fixed-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <div class="brand-icon">
                        <i class="fas fa-home"></i>
                    </div>
                    <span class="brand-text">VillaWeb</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-2"></i>Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">
                                <i class="fas fa-shield-alt me-2"></i>Privacy
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Villa" asp-action="Index">
                                <i class="fas fa-building me-2"></i>Villas
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="VillaNumber" asp-action="Index">
                                <i class="fas fa-hashtag me-2"></i>Villa Numbers
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
        
        <!-- Enhanced Hero Section -->
        <div class="hero-section position-relative overflow-hidden">
            <div class="hero-particles"></div>
            <div class="container position-relative">
                <div class="row align-items-center min-vh-75">
                    <div class="col-lg-6">
                        <div class="hero-content">
                            <h1 class="hero-title mb-4">
                                Welcome to <span class="text-gradient">VillaWeb</span>
                            </h1>
                            <p class="hero-subtitle mb-5">
                                Experience luxury property management like never before. 
                                Manage your villas and villa numbers with our cutting-edge platform 
                                designed for modern property professionals.
                            </p>
                            <div class="hero-buttons">
                                <a href="#get-started" class="btn btn-primary btn-lg me-3 mb-2">
                                    <i class="fas fa-rocket me-2"></i>Get Started
                                </a>
                                <a href="#" class="btn btn-outline-light btn-lg mb-2">
                                    <i class="fas fa-play me-2"></i>Watch Demo
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="hero-visual">
                            <div class="floating-card card-1">
                                <i class="fas fa-home"></i>
                                <span>150+ Villas</span>
                            </div>
                            <div class="floating-card card-2">
                                <i class="fas fa-users"></i>
                                <span>Happy Clients</span>
                            </div>
                            <div class="floating-card card-3">
                                <i class="fas fa-chart-line"></i>
                                <span>98% Satisfaction</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Decorative elements -->
            <div class="hero-shape-1"></div>
            <div class="hero-shape-2"></div>
        </div>
    </header>

    <div class="container mt-5 mb-5 content-wrapper">
        <section id="get-started">
            <main role="main" class="pb-5">
                @RenderBody()
            </main>    
        </section>
    </div>

    <!-- Enhanced Footer -->
    <footer class="footer-modern">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4">
                    <div class="footer-brand d-flex align-items-center mb-3">
                        <div class="brand-icon me-3">
                            <i class="fas fa-home"></i>
                        </div>
                        <span class="brand-text">VillaWeb</span>
                    </div>
                    <p class="footer-description">
                        Revolutionizing property management with innovative solutions 
                        and exceptional user experience.
                    </p>
                    <div class="social-links">
                        <a href="#" class="social-link"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="social-link"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="social-link"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#" class="social-link"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6 mb-4">
                    <h6 class="footer-title">Quick Links</h6>
                    <ul class="footer-links">
                        <li><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a asp-area="" asp-controller="Villa" asp-action="Index">Villas</a></li>
                        <li><a asp-area="" asp-controller="VillaNumber" asp-action="Index">Villa Numbers</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-6 mb-4">
                    <h6 class="footer-title">Support</h6>
                    <ul class="footer-links">
                        <li><a href="#">Help Center</a></li>
                        <li><a href="#">Contact Us</a></li>
                        <li><a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 mb-4">
                    <h6 class="footer-title">Stay Updated</h6>
                    <p class="mb-3">Subscribe to get the latest updates and features.</p>
                    <div class="newsletter-form">
                        <div class="input-group">
                            <input type="email" class="form-control" placeholder="Enter your email">
                            <button class="btn btn-primary" type="button">
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <hr class="footer-divider">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <p class="footer-copyright mb-0">
                        © 2025 VillaWeb. All rights reserved.
                    </p>
                </div>
                <div class="col-md-6 text-md-end">
                    <div class="footer-badges">
                        <span class="badge bg-success me-2">
                            <i class="fas fa-shield-check me-1"></i>Secure
                        </span>
                        <span class="badge bg-primary">
                            <i class="fas fa-award me-1"></i>Premium
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <!-- Back to Top Button -->
    <button id="backToTop" class="back-to-top">
        <i class="fas fa-chevron-up"></i>
    </button>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Enhanced JavaScript -->
    <script>
        // Back to top functionality
        $(window).scroll(function() {
            if ($(this).scrollTop() > 200) {
                $('#backToTop').fadeIn();
            } else {
                $('#backToTop').fadeOut();
            }
        });
        
        $('#backToTop').click(function() {
            $('html, body').animate({scrollTop: 0}, 600);
            return false;
        });
        
        // Navbar scroll effect
        $(window).scroll(function() {
            if ($(this).scrollTop() > 50) {
                $('.navbar-glass').addClass('scrolled');
            } else {
                $('.navbar-glass').removeClass('scrolled');
            }
        });
        
        // Animate floating cards
        function animateCards() {
            $('.floating-card').each(function(index) {
                $(this).css('animation-delay', (index * 0.2) + 's');
            });
        }
        
        $(document).ready(function() {
            animateCards();
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>