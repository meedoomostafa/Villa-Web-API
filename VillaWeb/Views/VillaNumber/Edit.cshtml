@model VillaNumberUpdateDTO

@{
    ViewBag.Title = "Edit Villa Number";
    Layout = "_Layout";
}

<div class="container p-4 border">
    <h1 class="text-primary"><i class="fas fa-edit me-2"></i>Edit Villa Number</h1>
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="VillaNo" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group mb-3">
            <label asp-for="VillaId" class="form-label"></label>
            <input asp-for="VillaId" type="number" class="form-control" placeholder="Enter Villa Id"></input>
            <span asp-validation-for="VillaId" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="SpetialDeatils" class="form-label"></label>
            <input asp-for="SpetialDeatils" type="text" class="form-control" placeholder="Enter Details" />
            <span asp-validation-for="SpetialDeatils" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Update</button>
            <a asp-action="Index" class="btn btn-secondary ms-2"><i class="fas fa-arrow-left me-1"></i>Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}