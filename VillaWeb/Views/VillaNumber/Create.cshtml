@model VillaNumberCreateDTO

@{
    ViewBag.Title = "Create Villa Number";
    Layout = "_Layout";
}

<div class="container p-4 border">
    <h1 class="text-primary"><i class="fas fa-plus me-2"></i>Create New Villa</h1>
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group mb-3">
            <label asp-for="VillaNo" class="form-label"></label>
            <input asp-for="VillaNo" ctype="number" class="form-control" placeholder="Enter Villa Number" />
            <span asp-validation-for="VillaNo" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="VillaId" class="form-label"></label>
            <textarea asp-for="VillaId" type="number" class="form-control" placeholder="Enter Villa Id"></textarea>
            <span asp-validation-for="VillaId" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="SpetialDeatils" class="form-label"></label>
            <input asp-for="SpetialDeatils" type="text" class="form-control" placeholder="Enter Details" />
            <span asp-validation-for="SpetialDeatils" class="text-danger"></span>
        </div>
        
        <div class="form-group mb-3">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Save</button>
            <a asp-action="Index" class="btn btn-secondary ms-2"><i class="fas fa-arrow-left me-1"></i>Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}